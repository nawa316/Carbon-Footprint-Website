# Backend server port (Cloud Run biasanya inject PORT otomatis)
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/carbon

# JWT secret key
JWT_SECRET=replace_with_a_long_random_secret

# Gmail SMTP credentials (gunakabackend/.env.examplen App Password, bukan password akun utama)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key

# Public base URL backend untuk link email verification/reset
# Contoh production: https://your-backend-xxxxx.a.run.app
BACKEND_BASE_URL=http://localhost:5000
