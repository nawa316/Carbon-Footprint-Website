# Backend server port (Cloud Run biasanya inject PORT otomatis)
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/carbon

# JWT secret key
JWT_SECRET=replace_with_a_long_random_secret

# Mailtrap Configuration (SMTP)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_username
MAILTRAP_PASS=your_mailtrap_password
MAILTRAP_SENDER_EMAIL=hello@demomailtrap.co
MAILTRAP_SENDER_NAME=Carbon Footprint App

# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key

# Public base URL backend untuk link email verification/reset
# Contoh production: https://your-backend-xxxxx.a.run.app
BACKEND_BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:3000
